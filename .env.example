# ─── Base de Datos ───────────────────────────────────
DB_USER=
DB_PASSWORD=
DB_SERVER=localhost
DB_NAME=StockDB
DB_PORT=1433

# ─── Servidor ────────────────────────────────────────
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# ─── Frontend ────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── JWT ─────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── CORS ────────────────────────────────────────────
# Separar múltiples orígenes con coma: http://a.com,http://b.com
ALLOWED_ORIGINS=http://localhost:3000
